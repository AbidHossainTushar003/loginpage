<?xml version="1.0" encoding="utf-8"?>
<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.apple.com/apk/res-auto">

    <Transition
        app:constraintSetStart="@+id/expandedState"
        app:constraintSetEnd="@+id/collapsedState"
        app:duration="1000">
        <OnSwipe
            app:touchAnchorId="@+id/motionCanvasHeader"
            app:touchAnchorSide="bottom"
            app:dragDirection="dragUp" />
    </Transition>

    <ConstraintSet android:id="@+id/expandedState">
        <Constraint android:id="@id/toolbarBackgroundOverlay">
            <Layout
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
            <PropertySet android:alpha="0.0" />
        </Constraint>

        <Constraint android:id="@id/profileAvatarBadge">
            <Layout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/liveStreamPreview"
                app:layout_constraintBottom_toBottomOf="@id/liveStreamPreview" />
        </Constraint>
    </ConstraintSet>

    <ConstraintSet android:id="@+id/collapsedState">
        <Constraint android:id="@id/toolbarBackgroundOverlay">
            <Layout
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
            <PropertySet android:alpha="1.0" />
        </Constraint>

        <Constraint android:id="@id/profileAvatarBadge">
            <Layout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </Constraint>

        <Constraint android:id="@id/txtWorkspaceTitle">
            <Layout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:layout_constraintBottom_toBottomOf="@id/profileAvatarBadge"
                app:layout_constraintStart_toEndOf="@id/profileAvatarBadge"
                app:layout_constraintTop_toTopOf="@id/profileAvatarBadge" />
            <CustomAttribute
                app:attributeName="textSize"
                app:customFloatValue="16" />
        </Constraint>
    </ConstraintSet>
</MotionScene>